# ===========================================
# Thumbnail Generator v2 - Environment Config
# ===========================================
# Copy this file to .env and fill in your API keys

# REQUIRED: Anthropic API Key (for Claude)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# REQUIRED: Google API Key(s) for Gemini image generation
# Get yours at: https://makersuite.google.com/app/apikey
# You can add multiple keys separated by commas for higher rate limits
GOOGLE_API_KEYS=your-key-1,your-key-2

# OPTIONAL: Replicate API Token (for Flux and SDXL models)
# Get yours at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxx

# OPTIONAL: Ideogram API Key (best for text in images)
# Get yours at: https://ideogram.ai/api
IDEOGRAM_API_KEY=xxxxx

# ===========================================
# Model Settings (optional overrides)
# ===========================================

# Claude model to use for ideation
# Default: claude-opus-4-5-20251101
CLAUDE_MODEL=claude-opus-4-5-20251101

# Thinking budget for Claude's extended thinking
# Higher = more thorough but slower and more expensive
# Default: 10000
THINKING_BUDGET_TOKENS=10000
